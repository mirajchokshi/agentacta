{
  "name": "agentacta",
  "version": "2026.4.8",
  "description": "Audit trail and search engine for AI agent sessions",
  "main": "dist/index.js",
  "bin": {
    "agentacta": "index.js"
  },
  "files": [
    "index.js",
    "dist/",
    "public/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "index": "node dist/indexer.js",
    "test": "tsx --test tests/*.test.ts",
    "demo": "node scripts/seed-demo.js && node dist/index.js --demo",
    "seed-demo": "node scripts/seed-demo.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "agent",
    "audit",
    "search",
    "openclaw",
    "claude",
    "sessions",
    "tool-calls",
    "sqlite",
    "fts5"
  ],
  "author": "Miraj Chokshi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirajchokshi/agentacta.git"
  },
  "homepage": "https://github.com/mirajchokshi/agentacta",
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "tar-fs": "^3.0.6",
    "npmlog": "^7.0.1"
  }
}
